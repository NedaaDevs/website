{
  "name": "nedaa-website",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "bun run scripts/fetch-release.ts && bun run scripts/fetch-prayers.ts && astro check && astro build",
    "fetch:release": "bun run scripts/fetch-release.ts",
    "fetch:prayers": "bun run scripts/fetch-prayers.ts",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro",
    "format": "prettier --write \"src/**/*.{astro,svelte,ts,tsx,md}\"",
    "lhci": "lhci autorun"
  },
  "packageManager": "bun@1.2.21",
  "trustedDependencies": ["esbuild", "sharp"],
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/svelte": "^8.1.0",
    "@fontsource-variable/asap": "^5.2.9",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/ibm-plex-sans-arabic": "^5.2.6",
    "astro": "^6.3.1",
    "motion": "^12.23.20",
    "svelte": "^5.43.6",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.4.0"
  }
}
