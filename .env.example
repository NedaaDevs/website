# Public config. Read directly by `astro dev`; in the Docker image these are
# injected at container start (docker/runtime-env.sh), so one image serves any env.

# Nedaa API base (stats ledger).
PUBLIC_NEDAA_API=

# Self-hosted Rybbit analytics; loads in prod only when both are set.
PUBLIC_RYBBIT_HOST=
PUBLIC_RYBBIT_SITE_ID=

# Crowdin project page (footer + localization links).
PUBLIC_CROWDIN_PROJECT_URL=
