---
import '@/styles/global.css';
import { Font } from 'astro:assets';
import { type Locale, dirFor, useTranslations } from '@/i18n/utils';
import { ogPathFor } from '@/lib/og-manifest';
import ScrollWidgets from '@/components/ScrollWidgets.astro';
import Analytics from '@/components/Analytics.astro';

type Props = {
  title: string;
  description?: string;
  locale?: Locale;
  jsonLd?: unknown;
  ogSlug?: string;
};

const {
  title,
  description,
  locale = 'en',
  jsonLd,
  ogSlug,
} = Astro.props;
const dir = dirFor(locale);
const tLang = locale === 'ar' ? 'ar' : 'en';
const t = useTranslations(tLang);
const resolvedDescription = description ?? t('site.description');

const pathname = Astro.url.pathname.replace(/\/$/, '');
const ogPath = ogSlug ? `/og/${ogSlug}.png` : ogPathFor(pathname, locale);
const canonical = new URL(pathname || '/', Astro.site).toString();
const ogImage = new URL(ogPath, Astro.site).toString();
---

<!doctype html>
<html lang={locale} dir={dir} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1c5d85" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Nedaa" />
    <meta property="og:locale" content={locale === 'ar' ? 'ar_SA' : 'en_US'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImage} />
    {locale === 'ar' || locale === 'ur' ? (
      <Fragment>
        <Font cssVariable="--f-arabic" preload />
        <Font cssVariable="--f-sans" />
      </Fragment>
    ) : (
      <Fragment>
        <Font cssVariable="--f-sans" preload />
        <Font cssVariable="--f-arabic" />
      </Fragment>
    )}
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <Analytics />
  </head>
  <body>
    <ScrollWidgets />
    <slot />
    <script>
      import { autoRise } from '@/lib/motion';

      const stored = localStorage.getItem('nedaa.theme');
      if (stored === 'dark' || stored === 'light') {
        document.documentElement.dataset.theme = stored;
      }

      const run = () => autoRise();
      if (document.readyState !== 'loading') run();
      else document.addEventListener('DOMContentLoaded', run);
    </script>
  </body>
</html>
