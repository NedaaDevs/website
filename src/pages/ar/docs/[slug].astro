---
import { render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import TopNav from '@/components/TopNav.astro';
import Footer from '@/components/Footer.astro';
import Icon from '@/components/Icon.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '@/i18n/utils';
import { getPublishedDocs, docMeta } from '@/lib/docs';
import { gregorianShort } from '@/lib/format';

export const getStaticPaths = async () => {
  const all = await getPublishedDocs('ar');
  return all.map((entry) => ({
    params: { slug: docMeta(entry).slug },
    props: { entry },
  }));
};

const { entry } = Astro.props;
const { Content } = await render(entry);

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const path = useTranslatedPath(lang);
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  locale={lang}
>
  <TopNav />
  <main class="section doc">
    <div class="shell-narrow">
      <a class="back" href={path('/docs')}>
        <Icon name="arrow-end" size={14} class="back-arrow" />
        {t('docs.back')}
      </a>

      <article class="prose">
        <header class="doc-head">
          {entry.data.last_updated && (
            <span class="marginalia">{gregorianShort(lang, entry.data.last_updated)}</span>
          )}
          <h1 class="h-display doc-h1">{entry.data.title}</h1>
          {entry.data.description && (
            <p class="lead doc-desc">{entry.data.description}</p>
          )}
        </header>
        <hr class="rule doc-rule" />
        <Content />
      </article>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .doc { padding-top: 64px; }
  .shell-narrow {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 32px;
  }
  @media (max-width: 768px) {
    .shell-narrow { padding: 0 20px; }
  }

  .back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--type-2);
  }
  .back:hover { color: var(--accent); }
  .back-arrow { transform: scaleX(-1); }
  :global([dir='rtl']) .back-arrow { transform: none; }

  .doc-head {
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .doc-h1 { font-size: clamp(36px, 4.8vw, 56px); margin: 0; }
  .doc-desc { margin: 0; }
  .doc-rule { margin: 32px 0; }

  .prose :global(h2) {
    font-family: var(--f-arabic);
    font-weight: 600;
    font-size: 24px;
    line-height: 1.3;
    margin-top: 48px;
    margin-bottom: 12px;
  }
  .prose :global(h3) {
    font-family: var(--f-arabic);
    font-weight: 600;
    font-size: 18px;
    margin-top: 32px;
    margin-bottom: 8px;
  }
  .prose :global(p),
  .prose :global(li) {
    color: var(--type);
    line-height: 1.75;
  }
  .prose :global(p) { margin: 16px 0; }
  .prose :global(strong) { color: var(--type); }
  .prose :global(ul),
  .prose :global(ol) { padding-inline-start: 22px; margin: 16px 0; }
  .prose :global(li) { margin: 6px 0; }
  .prose :global(a) {
    color: var(--accent);
    border-bottom: 1px solid color-mix(in oklab, var(--accent) 40%, transparent);
  }
  .prose :global(code) {
    font-family: var(--f-mono);
    font-size: 0.9em;
    background: var(--bg-muted);
    padding: 2px 6px;
    border-radius: 4px;
  }
</style>
