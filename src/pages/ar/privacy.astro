---
import Layout from '@/layouts/Layout.astro';
import TopNav from '@/components/TopNav.astro';
import Footer from '@/components/Footer.astro';
import { getLangFromUrl, useTranslatedPath } from '@/i18n/utils';
import release from '@/data/release.json';
import { gregorianShort } from '@/lib/format';
import '@/styles/doc-page.css';

const lang = getLangFromUrl(Astro.url);
const path = useTranslatedPath(lang);
const lastUpdated = gregorianShort(lang, new Date(release.releaseDate));
---

<Layout
  title="سياسة الخصوصية — نداء"
  description="كيف يتعامل نداء مع بياناتك. بكلامٍ صريح، بلا حروفٍ صغيرة."
  locale={lang}
>
  <TopNav />
  <main class="section doc">
    <div class="shell-narrow">
      <article class="prose">
        <header class="doc-head">
          <span class="marginalia">آخر تحديث · {lastUpdated}</span>
          <h1 class="h-display doc-h1">سياسة الخصوصية</h1>
          <p class="lead doc-desc">
            نداء تطبيقٌ للهاتف، يبنيه ويُصدره NedaaDev — مجتمعٌ من المساهمين. هذه السياسة تشرح ما يفعله نداء،
            وما لا يفعله، ببياناتك. بكلامٍ صريح، بلا حروفٍ صغيرة.
          </p>
        </header>
        <hr class="rule doc-rule" />

        <h2>الخلاصة</h2>
        <ul>
          <li>لا نجمع بياناتٍ شخصية. لا حسابات. لا تتبّع.</li>
          <li>بعض الأشياء تجري على جهازك فقط (إعداداتك، أذكارك المخصّصة، عدّاد قضاء صيامك).</li>
          <li>
            ما قد يصلنا فقط: تقارير الأعطال المجهولة الهوية من متجر التطبيقات (تلقائيًا، كأيّ تطبيق)،
            تفاصيل الأعطال عبر Sentry (معطّلٌ افتراضيًا، يعمل بإذنك)، ملفّات سجلّات ترسلها بنفسك للدعم،
            وطلبات مواقيت الصلاة عبر واجهتنا (لا نحتفظ بعناوين IP، أو رؤوس الطلبات، أو محتواها).
          </li>
          <li>لمسحِ بياناتك: احذف التطبيق. لا شيءَ على خادمٍ لنحذفه.</li>
        </ul>

        <h2>ما نجمعه، وكيف، ولماذا</h2>

        <h3>على جهازك فقط (لا يصلنا منه شيء)</h3>
        <ul>
          <li>إعداداتك، أذكارك المخصّصة، وعدّاد قضاء صيامك. تُحفظ على جهازك ليعمل التطبيق بين الجلسات.</li>
          <li>موقعك (فقط إن أذنت). لحساب مواقيتك. دقّة منخفضة. لا يغادر جهازك أبدًا.</li>
        </ul>

        <h3>ما قد يصلنا — وفقط بهذه الشروط</h3>
        <ul>
          <li>
            <strong>تقارير الأعطال من المتجر.</strong> عند تعطّل التطبيق، يُرسل متجرك (Apple أو Google)
            تقارير مجهولة الهوية. نفس ما يحدث لأيّ تطبيق؛ والمتجر هو من يدير ذلك، لا نحن.
          </li>
          <li>
            <strong>تفاصيل Sentry (بإذنك).</strong> إن فعّلتَ Sentry في إعدادات نداء، تصلنا تفاصيل الأعطال
            لمساعدتنا في إصلاح الأخطاء. معطّلٌ افتراضيًا. يمكنك إيقافه في أيّ وقت.
          </li>
          <li>
            <strong>ملفّات سجلّات ترسلها أنت.</strong> إن راسلتنا للدعم وأرفقت ملفّ سجلّات، يصلنا ما أرسلته.
            قد يحوي معلومات الجهاز ونظام التشغيل وما فعله التطبيق قبل المشكلة. نستخدمها فقط لمساعدتك.
          </li>
          <li>
            <strong>طلبات مواقيت الصلاة.</strong> واجهتنا وسيطٌ يُمرّر الطلبات إلى مزوّد للمواقيت —
            حاليًا Aladhan، وهو مفتوح المصدر. يطلب نداء المواقيت مرّةً في السنة تقريبًا لكلّ منطقة،
            مع طلبٍ إضافي حين تغيّر إعدادًا يستلزم تحديث المواقيت (كطريقة الحساب أو مذهب العصر)؛
            وبقيّة العام، تُقرأ المواقيت من ذاكرة جهازك. عند وسيطنا، تُقرَّب إحداثياتك إلى شبكةٍ تقريبية
            قبل التمرير — ولا يصل المزوّد إلا منطقتك التقريبية. ولا نحتفظ بالإحداثيات الفعلية، ولا بعناوين IP،
            ولا برؤوس الطلبات، ولا بمحتواها.
          </li>
        </ul>

        <h3>ما لا نجمعه أبدًا</h3>
        <ul>
          <li>لا حسابات، لا تسجيل، لا بريد، ولا كلمات مرور.</li>
          <li>لا أدوات إعلانات.</li>
          <li>لا أدوات تحليل تتعقّبك أو تصنّفك.</li>
          <li>لا تخرج بيانات موقعك من جهازك — أبدًا.</li>
          <li>لا وسطاء بيانات.</li>
          <li>لا ملفّات تعريف ارتباط، ولا تتبّعٌ بين المواقع.</li>
        </ul>

        <h2>كيف نستخدم ما يصلنا</h2>
        <ul>
          <li><strong>بيانات الأعطال</strong> نستخدمها لتشخيص الأخطاء وإصلاحها. لا نبيعها، ولا نشاركها، ولا نستخدمها لأيّ غرضٍ آخر.</li>
          <li><strong>السجلّات التي ترسلها</strong> نستخدمها فقط للردّ على طلب الدعم.</li>
          <li><strong>طلبات المواقيت</strong> نخدمها ثمّ نتجاهلها؛ لا نحتفظ بشيءٍ يُعرّف بمن طلبها.</li>
        </ul>

        <h2>المشاركة والأطراف الخارجية</h2>
        <p>نداء يستخدم عددًا قليلًا من الأطراف الخارجية فقط للتشغيل. لا تُباع البيانات ولا تُشارَك مع المعلنين.</p>
        <ul>
          <li><strong>متجر تطبيقاتك</strong> (Apple App Store، Google Play، Huawei AppGallery) — يوزّع التطبيق ويُبلّغ عن الأعطال بشكل مجهول.</li>
          <li><strong>Sentry</strong> (فقط إن فعّلتَ) — يستلم تفاصيل الأعطال. تنطبق سياسة Sentry على البيانات التي يعالجها بالنيابة عنّا.</li>
          <li><strong>واجهة نداء</strong> — نُديرها بأنفسنا؛ وسيطٌ يُمرّر طلبات المواقيت المُقرَّبة إلى مزوّد. لا احتفاظ كما هو موضّح أعلاه.</li>
          <li><strong>Aladhan</strong> — المزوّد الحالي خلف وسيطنا، مفتوح المصدر. يستلم منطقتك التقريبية فقط، لا موقعك الفعلي ولا أيّ معرّفات للجهاز.</li>
        </ul>
        <p>لا نتعامل مع شبكات إعلانية، ولا شبكات تحليل، ولا وسطاء بيانات.</p>

        <h2>مدّة الاحتفاظ</h2>
        <ul>
          <li><strong>تقارير الأعطال</strong> عبر Sentry تُحفظ بالقدر اللازم للتشخيص، ثمّ تُحذف.</li>
          <li><strong>رسائل الدعم وملفّاتها المرفقة</strong> تُحفظ ما دامت محادثة الدعم نشطة، ثمّ تُحذف.</li>
          <li><strong>سجلّات الواجهة</strong>: أعداد مجمَّعة فقط؛ لا بيانات تعريفية محفوظة.</li>
        </ul>

        <h2>حقوقك</h2>
        <p>
          لأنّ نداء لا يحتفظ بحسابات ولا ببيانات شخصية على خادم، فإنّ طلبات الوصول والحذف والنقل المعتادة
          غير ذات معنى — لا شيءَ لدينا للوصول إليه أو حذفه أو نقله.
        </p>
        <ul>
          <li><strong>لمسحِ كلّ بياناتك</strong>: احذف التطبيق. تُمسح البيانات المحلّية معه.</li>
          <li><strong>لإيقاف Sentry</strong>: عطّله من إعدادات نداء.</li>
          <li><strong>لأيّ سؤالٍ آخر</strong>: راسلنا على support@nedaa.dev، ونردّ خلال خمسة أيام عمل.</li>
        </ul>

        <h2>النقل الدولي</h2>
        <p>
          نداء متاحٌ عالميًا. بيانات الأعطال المُرسَلة إلى Sentry قد تُعالَج في مناطق خارج بلدك. إن لم ترغب
          بمغادرة أيّ بيانات لجهازك، لا تُفعّل Sentry؛ يعمل كلّ شيءٍ آخر محلّيًا أو بشكلٍ مجهول.
        </p>

        <h2>الأطفال</h2>
        <p>نداء مناسبٌ لكلّ عمر. لا نجمع معلوماتٍ شخصية من أحد، صغيرًا كان أو كبيرًا.</p>

        <h2>الأمان</h2>
        <p>نتّبع ممارساتٍ معتادة لحماية ما يصلنا من بيانات قليلة:</p>
        <ul>
          <li>HTTPS لجميع الاتصالات.</li>
          <li>بيانات الأعطال يصل إليها المطوّرون فقط.</li>
          <li>لا يوجد نظامٌ آمنٌ مئة بالمئة؛ سنُخطر المستخدمين فورًا إن وقع اختراقٌ يمسّهم.</li>
        </ul>

        <h2>التغييرات على هذه السياسة</h2>
        <p>
          إن غيّرنا هذه السياسة جوهريًا، نعرض إشعارًا واحدًا داخل التطبيق يمكنك إغلاقه — لا جدارَ نصٍّ
          يطلبُ قبولًا للمتابعة. التوضيحات غير الجوهرية قد تُنشر هنا دون إشعار. يعكس تاريخ السريان أعلاه أحدث نسخة.
        </p>

        <h2>التواصل</h2>
        <p>لأيّ سؤالٍ أو شكوى بخصوص الخصوصية، راسلنا على <a href="mailto:support@nedaa.dev">support@nedaa.dev</a>.</p>

        <hr class="rule" />
        <p>
          <em>نداء مفتوح المصدر. كودنا — بما فيه كلّ ما يلامس بياناتك — على
          <a href="https://github.com/NedaaDevs/nedaa">github.com/NedaaDevs/nedaa</a>.</em>
        </p>

        <p><a class="back" href={path('/privacy-stance')}>اقرأ موقفنا من الخصوصية ←</a></p>
      </article>
    </div>
  </main>
  <Footer />
</Layout>
