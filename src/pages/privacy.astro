---
import StubPage from '@/components/StubPage.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const path = useTranslatedPath(lang);
---

<StubPage
  eyebrow={t('nav.privacy')}
  title={t('stub.privacy.title')}
  body={t('stub.privacy.body')}
  links={[{ label: t('stub.privacy.link'), href: path('/privacy-stance'), primary: true }]}
/>
