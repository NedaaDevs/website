---
type Props = {
  size?: number;
  alt?: string;
};

const { size = 36, alt = 'Nedaa' } = Astro.props;
---

<picture class="brand" style={`--s:${size}px`}>
  <img class="brand-img brand-img-light" src="/logo.png" {alt} width={size} height={size} decoding="async" />
  <img
    class="brand-img brand-img-dark"
    src="/logo-dark.png"
    alt=""
    aria-hidden="true"
    width={size}
    height={size}
    decoding="async"
  />
</picture>
