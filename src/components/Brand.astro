---
import { Image } from 'astro:assets';
import lightLogo from '@/assets/logo.png';
import darkLogo from '@/assets/logo-dark.png';

type Props = {
  size?: number;
  alt?: string;
};

const { size = 36, alt = 'Nedaa' } = Astro.props;
---

<picture class="brand" style={`--s:${size}px`}>
  <Image
    class="brand-img brand-img-light"
    src={lightLogo}
    {alt}
    width={size * 2}
    height={size * 2}
    densities={[1, 2]}
    format="webp"
    loading="eager"
  />
  <Image
    class="brand-img brand-img-dark"
    src={darkLogo}
    alt=""
    width={size * 2}
    height={size * 2}
    densities={[1, 2]}
    format="webp"
    loading="eager"
  />
</picture>
