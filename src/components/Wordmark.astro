---
type Props = {
  size?: 'sm' | 'md' | 'lg';
  withArabic?: boolean;
};

const { size = 'md', withArabic = true } = Astro.props;

const dims = {
  sm: { latin: 16, arabic: 18, gap: 10 },
  md: { latin: 20, arabic: 22, gap: 12 },
  lg: { latin: 28, arabic: 30, gap: 16 },
}[size];
---

<span class="wordmark" style={`--gap:${dims.gap}px; --rule:${dims.latin * 0.9}px`}>
  <span class="latin" style={`font-size:${dims.latin}px`}>Nedaa</span>
  {
    withArabic && (
      <>
        <span class="rule" aria-hidden="true" />
        <span class="arabic" lang="ar" dir="rtl" style={`font-size:${dims.arabic}px`}>
          نداء
        </span>
      </>
    )
  }
</span>

<style>
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--gap);
    color: var(--type);
  }
  .latin {
    font-family: var(--f-sans);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .rule {
    width: 1px;
    height: var(--rule);
    background: var(--outline-strong);
  }
  .arabic {
    font-family: var(--f-arabic);
    font-weight: 500;
  }
</style>
