---
import Brand from '@/components/Brand.astro';
import Wordmark from '@/components/Wordmark.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '@/i18n/utils';
import { CROWDIN_URL } from '@/lib/links';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const path = useTranslatedPath(lang);

const product = [
  { href: path('/download'), label: t('nav.download') },
  { href: path('/privacy'), label: t('nav.privacy') },
  { href: path('/docs'), label: t('nav.docs') },
];
const community = [
  { href: 'https://github.com/NedaaDevs/nedaa', label: t('footer.github') },
  { href: CROWDIN_URL, label: t('footer.translate') },
];
const contact = [{ href: path('/support'), label: t('nav.support') }];

// Live status: ping ${PUBLIC_NEDAA_API}/v3/health at runtime and flip the badge
// to "down" if it doesn't answer ok. Base is a runtime-substituted token, so the
// check stays inline in the HTML (cache-safe); empty/unsubstituted → stays static.
const apiBase = import.meta.env.PUBLIC_NEDAA_API ?? '';
const healthScript = `(function(){
  var base=${JSON.stringify(apiBase)}.replace(/\\/+$/,'');
  if(!base||base.charAt(0)==='%')return;
  var box=document.querySelector('footer.site .status');
  if(!box)return;
  var dot=box.querySelector('.dot'),label=box.querySelector('.status-label');
  var down=function(){dot.dataset.state='down';label.textContent=${JSON.stringify(t('footer.status.down'))};};
  fetch(base+'/v3/health',{cache:'no-store'}).then(function(r){return r.ok?r.json():null;}).then(function(d){if(!d||d.status!=='ok')down();}).catch(down);
})();`;
---

<footer class="site">
  <div class="shell">
    <div class="grid">
      <div class="stack stack-4">
        <a href={path('/')} class="brand-link">
          <Brand size={28} />
          <Wordmark size="sm" />
        </a>
        <p class="body" style="max-width:38ch">{t('footer.tagline')}</p>
      </div>

      <div>
        <h2 class="col-title">{t('footer.product')}</h2>
        <ul>
          {product.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
        </ul>
      </div>

      <div>
        <h2 class="col-title">{t('footer.community')}</h2>
        <ul>
          {community.map((l) => (<li><a href={l.href} target="_blank" rel="noopener noreferrer">{l.label}</a></li>))}
        </ul>
      </div>

      <div>
        <h2 class="col-title">{t('footer.contact')}</h2>
        <ul>
          {contact.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
        </ul>
      </div>
    </div>

    <div class="colophon">
      <span>{t('footer.copy')}</span>
      <span>{t('footer.license')}</span>
      <span class="status">
        <span aria-hidden="true" class="dot"></span>
        <span class="status-label">{t('footer.status')}</span>
      </span>
      <script is:inline set:html={healthScript} />
    </div>
  </div>
</footer>

<style>
  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .status .dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--success-bd);
  }
  .status .dot[data-state='down'] {
    background: var(--error-bd);
  }
</style>
